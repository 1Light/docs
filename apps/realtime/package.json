{
  "name": "@repo/realtime",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -e .env -- ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"(optional) add eslint later\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@repo/contracts": "workspace:*",
    "axios": "^1.13.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.5",
    "yjs": "^13.6.18",
    "y-protocols": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.19.15",
    "dotenv-cli": "^11.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.0.5"
  }
}